# ── RabbitMQ ──────────────────────────────────────────────────────────────────
# dev profile:  use rabbitmq container name
# bdp profile:  use the infrastructure-v2 rabbitmq container name

MQ_URI=amqp://guest:guest@infrastructure-v2-rabbitmq-1:5672
MQ_CLIENT=tr-webcam-panocloud # identify your datacollector to rabbitmq
MQ_EXCHANGE=ingress # Must match the collector's exchange (api-crawler uses "ingress")
MQ_QUEUE=panocloud.webcams
MQ_KEY=panocloud.webcams

# ── Raw data bridge ───────────────────────────────────────────────────────────
# Used by the SDK to fetch raw payloads from MongoDB
RAW_DATA_BRIDGE_ENDPOINT=http://infrastructure-v2-bridge-1:2000/

# ── ODH Content API ───────────────────────────────────────────────────────────
ODH_CORE_URL=https://tourism.api.opendatahub.testingmachine.eu/v1/
ODH_CORE_TOKEN_URL=https://auth.opendatahub.testingmachine.eu/auth/realms/noi/protocol/openid-connect/token
ODH_CORE_TOKEN_CLIENT_ID=odh-api-core-webcams-serviceaccount
ODH_CORE_TOKEN_CLIENT_SECRET=

INSECURE_SKIP_VERIFY=true
SKIP_SSL_VERIFY=true

# ── Telemetry ─────────────────────────────────────────────────────────────────
SERVICE_NAME=tr-webcam-panocloud
TELEMETRY_TRACE_GRPC_ENDPOINT=localhost:4317
LOG_LEVEL=DEBUG