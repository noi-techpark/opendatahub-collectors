LOG_LEVEL="DEBUG"
MQ_QUEUE=skidata.parking-stations
MQ_EXCHANGE=routed
MQ_KEY=skidata.parking-stations
MQ_CLIENT=tr-parking-skidata
MQ_URI=amqp://guest:guest@localhost:5672

BDP_BASE_URL=http://localhost:8081
BDP_PROVENANCE_VERSION=0.1.0
BDP_PROVENANCE_NAME=tr-parking-skidata
BDP_ORIGIN=skidata

ODH_TOKEN_URL=
ODH_CLIENT_ID=
ODH_CLIENT_SECRET=

RAW_DATA_BRIDGE_ENDPOINT="http://localhost:2000/"

SERVICE_NAME=tr-parking-skidata
TELEMETRY_TRACE_GRPC_ENDPOINT=

# Optional CSV overlay name. Set to "test" to also load
# resources/stations.test.csv + resources/counting_categories.test.csv
# on top of the base CSVs. Leave unset for production behaviour.
RESOURCES_OVERLAY=test

# OpenDataHub time-series API used to hydrate the in-memory cache at
# startup. Leave TS_API_BASE_URL empty to skip hydration (the cache
# starts empty and warms up from incoming push events).
TS_API_BASE_URL=https://mobility.api.opendatahub.testingmachine.eu
TS_API_TOKEN_URL=
TS_API_REFERER=tr-parking-skidata
