# MQ
MQ_URI=amqp://guest:guest@localhost:5672/
MQ_QUEUE=sudtirolwein.transformer
MQ_EXCHANGE=transformed
MQ_KEY=sudtirolwein.put
MQ_CLIENT=sudtirolwein.transformer

# ODH Content API
ODH_CORE_URL=https://api.tourism.testingmachine.eu/v1
ODH_CORE_TOKEN_URL=https://auth.opendatahub.testingmachine.eu/auth/realms/noi/protocol/openid-connect/token
ODH_CORE_TOKEN_CLIENT_ID=
ODH_CORE_TOKEN_CLIENT_SECRET=

# windows variables
INSECURE_SKIP_VERIFY=
SKIP_SSL_VERIFY=

# Telemetry
SERVICE_NAME=sudtirolwein.transformer
TELEMETRY_TRACE_GRPC_ENDPOINT=

# Logging
LOG_LEVEL=DEBUG
